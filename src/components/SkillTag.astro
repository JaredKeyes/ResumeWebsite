---
interface Props {
  name: string;
}
const { name } = Astro.props;
---
<span class="skill">{name}</span>

<style>
  .skill {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--fg);
    border: 1px solid var(--border);
    padding: 2px var(--space-2);
    margin: 0 var(--space-1) var(--space-1) 0;
  }
</style>
